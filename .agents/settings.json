{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./init.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Reminder: if you are editing specs/, confirm you are spec_author. If you are editing src/, confirm you are implementer.' 1>&2"
          }
        ]
      }
    ]
  }
}
