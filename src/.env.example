# Environment (dev | test)
APP_ENV=dev

# Database (backend) — REQUIRED
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# JWT — SECRET_KEY is REQUIRED
SECRET_KEY=COMPLETE
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# SMTP — SMTP_FROM_EMAIL is REQUIRED
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM_EMAIL=COMPLETE

# PostgreSQL (docker-compose)
POSTGRES_USER=COMPLETE
POSTGRES_PASSWORD=COMPLETE
POSTGRES_DB=flayer
POSTGRES_PORT=5432

# PostgreSQL Test (docker-compose) — used by conftest.py when APP_ENV=test
POSTGRES_TEST_USER=postgres
POSTGRES_TEST_PASSWORD=postgres
POSTGRES_TEST_DB=flayer_test
POSTGRES_TEST_PORT=5433

# pgAdmin (docker-compose)
PGADMIN_EMAIL=COMPLETE
PGADMIN_PASSWORD=COMPLETE
PGADMIN_PORT=5050

# Mailpit (docker-compose)
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
